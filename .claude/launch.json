{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Netlify Dev",
      "runtimeExecutable": "netlify",
      "runtimeArgs": ["dev", "--port", "8888"],
      "port": 8888
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "npx serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-p", "3000", "-s"],
      "port": 3000
    }
  ]
}
